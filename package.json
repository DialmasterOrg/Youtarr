{
  "name": "youtarr",
  "version": "1.72.1",
  "description": "",
  "main": "server/index.js",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "start": "node server/server.js",
    "lint": "eslint ./client/src/. --ext .ts,.tsx && eslint ./server/. --ext .js",
    "lint:frontend": "eslint ./client/src/. --ext .ts,.tsx",
    "lint:backend": "eslint ./server/. --ext .js",
    "lint:ts": "cd client && npx tsc --noEmit",
    "lint:fix": "eslint ./client/src/. --ext .ts,.tsx --fix && eslint ./server/. --ext .js --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "npm run test:backend -- --passWithNoTests && npm run test:frontend -- --passWithNoTests",
    "test:backend": "jest --config jest.config.js",
    "test:frontend": "cd client && npm test -- --watchAll=false",
    "test:coverage": "npm run lint && jest --config jest.config.js --coverage && cd client && npm test -- --coverage --watchAll=false",
    "test:watch": "jest --config jest.config.js --watch",
    "storybook": "cd client && npm run storybook"
  },
  "lint-staged": {
    "./client/src/*.{ts,tsx},./server/*.js": [
      "eslint --fix",
      "git add"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^6.5.1",
    "eslint": "^8.41.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "husky": "^8.0.3",
    "jest": "^30.1.3",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.4",
    "typescript": "5.9.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "form-data": "^4.0.6"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "fs-extra": "^11.1.1",
    "multer": "^2.2.0",
    "mysql2": "^3.9.4",
    "node-cron": "^4.2.1",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "sequelize": "^3.30.0",
    "sequelize-cli": "^6.6.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^2.3.0",
    "uuid": "^14.0.0",
    "ws": "^8.13.0"
  }
}
