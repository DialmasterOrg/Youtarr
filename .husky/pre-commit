#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running linter..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Linting failed. Please fix the errors before committing."
  exit 1
fi

echo "🔍 Running TypeScript type checking..."
npm run lint:ts
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type checking failed. Please fix the type errors before committing."
  exit 1
fi

echo "🧪 Running frontend tests..."
cd client && CI=true npm test -- --watchAll=false --passWithNoTests --silent
FRONTEND_RESULT=$?
cd ..

if [ $FRONTEND_RESULT -ne 0 ]; then
  echo "❌ Frontend tests failed. Please fix the failing tests before committing."
  exit 1
fi

echo "🧪 Running backend tests..."
npx jest --config jest.config.js --silent
BACKEND_RESULT=$?

if [ $BACKEND_RESULT -ne 0 ]; then
  echo "❌ Backend tests failed. Please fix the failing tests before committing."
  exit 1
fi

echo "✅ All checks passed!"
